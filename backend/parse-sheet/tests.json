{
  "tests": [
    {
      "name": "GET history",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"history": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST empty url",
      "method": "POST",
      "path": "/",
      "body": {"url": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "URL таблицы обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST invalid url",
      "method": "POST",
      "path": "/",
      "body": {"url": "https://example.com/not-a-sheet", "name": "Тест"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Не удалось определить ID таблицы. Проверьте ссылку."},
      "bodyMatcher": "partial"
    }
  ]
}
